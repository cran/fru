LIBDIR = fru/target/release
STATLIB = $(LIBDIR)/fru.a
PKG_CPPFLAGS = -DSTRICT_R_HEADERS -DR_NO_REMAP
PKG_LIBS = -L$(LIBDIR) -lfru -lws2_32 -ladvapi32 -lgdi32 -lbcrypt -lcrypt32 -luserenv -lntdll
export CARGO_HOME=$(PWD)/.cargo

all: cleanup

$(SHLIB): $(STATLIB)

$(STATLIB):
	mkdir -p $(CARGO_HOME)
	cargo build --release --offline -j 2 --manifest-path=fru/Cargo.toml
	-rm -Rf $(CARGO_HOME)
	-rm -Rf $(LIBDIR)/build
        
cleanup: $(SHLIB)
	@rm -Rf $(STATLIB) fru/target

